{
  "name": "blackhole",
  "version": "0.1.0",
  "description": "blackhole is a small util that syncing and sucking (downloading) your music from streaming services to local storage. It is intended to use on a NAS or homelab server.",
  "author": "Yuukari",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "start-once": "node build/index.js --once"
  },
  "dependencies": {
    "@blackglory/better-sqlite3-migrations": "^0.2.2",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "migration-files": "^0.4.3",
    "node-fetch": "^3.3.2",
    "node-schedule": "^2.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sqlite": "^5.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "@types/node-schedule": "^2.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
